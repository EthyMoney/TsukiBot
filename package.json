{
  "name": "tsukibot",
  "version": "1.0.0",
  "description": "Discord bot for cryptocurrency prices, charts, coin details, market statistics, personalized tracking tools, and so much more!",
  "main": "main.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "node main.js",
    "test": "echo \"Error: no tests available yet!\" && exit 1",
    "dev": "node main.js -d",
    "deploy": "node deploy-commands.js",
    "deploy:dev": "node deploy-commands.js --dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EthyMoney/TsukiBot.git"
  },
  "keywords": [
    "discord",
    "cryptocurrency",
    "crypto",
    "trading",
    "stocks",
    "bitcoin",
    "ethereum",
    "eth",
    "btc",
    "tsuki",
    "tsukibot"
  ],
  "author": "Logan S. (EthyMoney)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/EthyMoney/TsukiBot/issues"
  },
  "homepage": "https://github.com/EthyMoney/TsukiBot#readme",
  "dependencies": {
    "@google-cloud/translate": "^9.4.2",
    "ccxt": "^4.5.61",
    "coingecko-api": "^1.0.10",
    "coinmarketcap-api": "^3.1.1",
    "cryptocompare": "^1.0.0",
    "currencyexchanges": "^1.1.1",
    "didyoumean": "^1.2.2",
    "discord.js": "^14.26.4",
    "express": "^5.2.1",
    "fast-average-color-node": "^3.2.0",
    "finnhub": "^2.0.15",
    "graviex": "^1.0.0",
    "jsdom": "^29.1.1",
    "node-schedule": "^2.1.1",
    "pg": "^8.22.0",
    "picocolors": "^1.1.1",
    "puppeteer": "^25.2.1",
    "puppeteer-cluster": "^0.25.0",
    "string": "^3.3.3",
    "topgg-autoposter": "^2.0.2",
    "web3": "^4.16.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0"
  },
  "engines": {
    "node": ">=16.9.0",
    "npm": ">=8.13.3"
  },
  "allowScripts": {
    "bufferutil@4.1.0": true,
    "ccxt@4.5.61": true,
